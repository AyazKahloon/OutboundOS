# Copy to .env and fill in. Never commit .env.

# LLM (Groq) — the ONLY paid dependency. Used by researcher, reviews-analyst, and writer.
GROQ_API_KEY=

# Crawling (whole website) and Google reviews are done IN-HOUSE with a local headless
# browser (Playwright/Chromium). No scraping/search API keys, no per-request cost.
# Leads come from a Google-Maps CSV export.

# Database (Neon Postgres)
DATABASE_URL=

# Queue (Upstash Redis)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Outbound sender + offer (used by the writer agent)
SENDER_NAME=
SENDER_COMPANY=
OFFER=
# Optional model overrides
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_REVIEWS_MODEL=llama-3.3-70b-versatile
# GROQ_WRITER_MODEL=llama-3.3-70b-versatile

# App
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
